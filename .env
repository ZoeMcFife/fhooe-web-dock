# ==============================================
# fhooe-web-dock - Environment Configuration
# ==============================================

# --- Global System Settings ---
LANG=C.UTF-8


# ==============================================
# Database Configuration (MariaDB)
# ==============================================

# --- Internal Credentials ---
# These variables are used to initialize the database container
# and are used by the PHP application to connect internally.
MYSQL_DATABASE=default
MYSQL_USER=dbuser
MYSQL_PASSWORD=geheim
MYSQL_RANDOM_ROOT_PASSWORD=1
MYSQL_ROOT_HOST=%

# --- External Access ---
# Configuration for accessing the database from your host machine
DB_HOST_EXTERNAL=localhost
DB_PORT_EXTERNAL=6033


# ==============================================
# Web Application (PHP/Apache)
# ==============================================

# --- External Ports ---
# Map these ports to your host machine to access the dashboard.
# Example: http://localhost:8080
WEB_PORT_HTTP=8080
WEB_PORT_HTTPS=7443


# ==============================================
# FrankenPHP (Experimental)
# ==============================================

# --- External Ports ---
# FrankenPHP runs in parallel to Apache. Map these ports to your host machine.
# Example: http://localhost:8081
FRANKENPHP_WEB_PORT_HTTP=8081
FRANKENPHP_WEB_PORT_HTTPS=7444


# ==============================================
# Administration Tools (phpMyAdmin)
# ==============================================

# --- External Ports ---
# Map these ports to your host machine to access phpMyAdmin.
# Example: http://localhost:8082
PMA_PORT_HTTP=8082
PMA_PORT_HTTPS=8443